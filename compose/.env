# Grafana Monitoring Stack Environment Variables

# Base path for configuration files
# Default: /volume1/docker/grafana (Synology NAS path)
# Override with: GRAFANA_CONFIG_PATH=/your/custom/path
GRAFANA_CONFIG_PATH=/home/jclee/app/grafana

# Service versions
GRAFANA_VERSION=latest
PROMETHEUS_VERSION=latest
LOKI_VERSION=latest
ALERTMANAGER_VERSION=latest

# Grafana settings
GRAFANA_ADMIN_PASSWORD=bingogo1
GRAFANA_DOMAIN=grafana.jclee.me
PROMETHEUS_DOMAIN=prometheus.jclee.me
LOKI_DOMAIN=loki.jclee.me
ALERTMANAGER_DOMAIN=alertmanager.jclee.me

# Prometheus settings
PROMETHEUS_RETENTION=30d

# n8n settings
N8N_DB_PASSWORD=n8n_password
N8N_PASSWORD=bingogo1
